    {
      "parameters": {
        "jsCode": "// 1. Grab all the incoming lead items\nconst leads = $input.all().map(item => item.json);\n\n// 2. Filter to HOT leads only\nconst hotLeads = leads.filter(lead => \n  lead[\"Classification\"]?.toString().trim().toUpperCase() === \"HOT\"\n);\n\nconst leadCount = hotLeads.length;\n\n// 3. Build your clean array of JSON objects\nconst cleanedLeads = hotLeads.map(lead => {\n  return {\n    name: lead[\"Name\"],\n    company: lead[\"Company\"],\n    email: lead[\"Email address\"],\n    confidence_level: lead[\"Confidence level\"],\n    reason_for_confidence: lead[\"Reason for confidence\"],\n    suggested_action: lead[\"Suggested action\"]\n  };\n});\n\n// 4. Start building a single text summary for the email\nlet emailBody = `You have ${leadCount} new HOT leads to follow up with:`;\n\n// 5. Return EXACTLY ONE item containing BOTH the text and the clean list\nreturn [{ json: {\n  total_hot_leads: leadCount,\n  email_content: emailBody,\n  clean_lead_data: cleanedLeads\n} }];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
