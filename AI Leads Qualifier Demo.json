    {
      "parameters": {
        "jsCode": "// 1. Target the exact nested path from the Gemini API payload\nconst rawText = $input.first().json.candidates[0].content.parts[0].text;\n\nif (!rawText) {\n    throw new Error(\"Could not find text in the Gemini response payload.\");\n}\n\n// 2. Clean out the markdown fences safely without using regex\nlet cleanJsonString = rawText.trim();\n\nif (cleanJsonString.startsWith(\"```json\")) {\n    cleanJsonString = cleanJsonString.slice(7); // Strip off ```json\n} else if (cleanJsonString.startsWith(\"```\")) {\n    cleanJsonString = cleanJsonString.slice(3); // Strip off baseline ```\n}\n\nif (cleanJsonString.endsWith(\"```\")) {\n    cleanJsonString = cleanJsonString.slice(0, -3); // Strip off trailing ```\n}\n\ncleanJsonString = cleanJsonString.trim();\n\n// 3. Parse it into a standard JavaScript object\nconst parsedData = JSON.parse(cleanJsonString);\n\n// 4. Return it cleanly for downstream nodes\nreturn [{ json: parsedData }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
